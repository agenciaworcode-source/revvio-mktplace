# Supabase — copie para .env.local e preencha com os valores do seu projeto
# (Project Settings → API)

# ── Frontend (vão para o navegador via bundle Vite) ──────────
# A anon key é pública por design; o RLS é quem protege os dados.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Server-side / CLI local — NUNCA com prefixo VITE_ ────────
# ⚠️ A SERVICE ROLE KEY bypassa todo o RLS (acesso total ao banco).
# NÃO deve ter prefixo VITE_ (senão o Vite a empacota e ela vaza no browser).
# Uso exclusivo: scripts/CLI locais. NUNCA importe em src/.
# Nas Edge Functions deployadas o Supabase já injeta SUPABASE_SERVICE_ROLE_KEY
# automaticamente — não precisa setar lá.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── ASAAS (cobrança dos garagistas) — secreto, só Edge Functions ──
# Em produção, setar via `supabase secrets set` (não vai no bundle do app).
ASAAS_API_KEY=your-asaas-key
# obrigatória: sandbox | production. Sem valor válido as functions nem sobem.
ASAAS_ENV=sandbox
# obrigatório: o asaas-webhook é público (verify_jwt=false) e rejeita quem não mandar
# este token no header asaas-access-token. Mesmo valor no painel do ASAAS.
ASAAS_WEBHOOK_TOKEN=um-token-aleatorio-para-validar-o-webhook

# ── Resend (e-mails transacionais) — secreto, só Edge Functions ──
RESEND_API_KEY=your-resend-key
RESEND_FROM=REVVIO <no-reply@revvio.com.br>
# segredo compartilhado entre os triggers do banco (private.email_config) e send-email
EMAIL_TRIGGER_SECRET=troque-por-um-token-aleatorio-forte
# base usada nos links dos e-mails
APP_URL=http://localhost:5173
